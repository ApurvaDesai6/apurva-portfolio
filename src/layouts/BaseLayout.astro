---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Cloud Engineer at AWS. Building things in bits and occasionally atoms.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} · Apurva Desai</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" type="application/rss+xml" title="Apurva Desai" href="/rss.xml" />
  <meta property="og:title" content={`${title} · Apurva Desai`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
</html>
