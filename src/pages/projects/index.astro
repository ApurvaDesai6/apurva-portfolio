---
import PageLayout from '../../layouts/PageLayout.astro';
import { projects } from '../../data/projects';

const allTags = [...new Set(projects.flatMap(p => p.tags))].sort();
---
<PageLayout title="Projects">
  <blockquote class="epigraph">
    <p>"The best way to predict the future is to invent it."</p>
    <cite>— <a href="https://en.wikipedia.org/wiki/Alan_Kay">Alan Kay</a></cite>
  </blockquote>

  <div class="tag-filters">
    <a href="/projects" class="tag active">All</a>
    {allTags.map(tag => (
      <a href={`/projects/${tag.toLowerCase()}`} class="tag">{tag}</a>
    ))}
  </div>

  <div class="projects-grid">
    {projects.map(project => (
      <div class="project-card" data-has-video={project.video ? 'true' : 'false'}>
        <div class="card-media">
          {project.image ? (
            <img src={project.image} alt={project.name} loading="lazy" class="card-thumb" />
          ) : (
            <div class="card-placeholder">{project.name.charAt(0)}</div>
          )}
          {project.video && (
            <video src={project.video} loop muted playsinline class="card-video" style="display:none" />
          )}
          {project.badge && (
            <span class={`badge badge-${project.badge.toLowerCase().replace(/\s+/g, '-')}`}>{project.badge}</span>
          )}
        </div>
        <div class="card-title-row">
          <h3>
            {project.url ? (
              <a href={project.url}>{project.name}</a>
            ) : (
              project.name
            )}
          </h3>
          {project.github && (
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="gh-link" title="View source on GitHub">
              <svg viewBox="0 0 16 16" fill="currentColor" width="15" height="15"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            </a>
          )}
        </div>
        <p class="project-desc">{project.description}</p>
      </div>
    ))}
  </div>
</PageLayout>

<script>
  document.querySelectorAll('.project-card[data-has-video="true"]').forEach(card => {
    const img = card.querySelector('.card-thumb') as HTMLImageElement;
    const video = card.querySelector('.card-video') as HTMLVideoElement;
    if (!img || !video) return;
    card.addEventListener('mouseenter', () => {
      img.style.display = 'none';
      video.style.display = 'block';
      video.play();
    });
    card.addEventListener('mouseleave', () => {
      video.pause();
      video.style.display = 'none';
      img.style.display = 'block';
    });
  });
</script>

<style>
  .epigraph {
    border-left: none;
    font-family: 'Crimson Pro', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-muted);
    margin: 0 0 2rem;
    padding: 0;
  }
  .epigraph cite { font-style: normal; font-size: 0.85rem; }
  .tag-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .card-media {
    position: relative;
    margin-bottom: 0.5rem;
  }
  .card-media img, .card-media video {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
  }
  .card-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: #e8e5e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-muted);
  }
  .card-media .badge {
    position: absolute;
    top: 8px;
    right: 8px;
  }
  .card-title-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .card-title-row h3 {
    font-size: 1rem;
    margin: 0;
  }
  .card-title-row h3 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .card-title-row h3 a:hover { color: var(--color-accent); }
  .gh-link { color: var(--color-muted); transition: color 0.2s; display: flex; }
  .gh-link:hover { color: var(--color-text); }
  .project-desc {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0.25rem 0 0;
  }
</style>
